{
  "name": "tribelife-backend",
  "version": "1.0.0",
  "description": "TribeLife mobile backend — Express + Socket.io + Drizzle",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:web": "cd web && npm run dev",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:web\"",
    "build": "tsc",
    "build:web": "cd web && npm install && npm run build && cp -r dist ../public",
    "build:all": "npm run build:web && npm run build",
    "start": "node dist/server.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:promo": "tsx src/db/seed-promo.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@aws-sdk/client-s3": "^3.1017.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/pg": "^8.11.10",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.0.0",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "openai": "^6.25.0",
    "pg": "^8.13.3",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.4",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
