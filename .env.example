# Database
DATABASE_URL=postgresql://user:password@host:5432/tribelife

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your-expo-access-token

# Server
PORT=4000
CLIENT_URL=http://localhost:8081
NODE_ENV=development

# Content Moderation (optional: Perspective API key for enhanced moderation)
PERSPECTIVE_API_KEY=

# Email (SendGrid) — used for welcome emails and support form routing.
# If SENDGRID_API_KEY is unset, outbound emails become no-ops with a log line
# (dev-friendly — you can build and test flows without a real key).
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@tribelife.app
SENDGRID_FROM_NAME=TribeLife

# News Ingestion
WORLD_NEWS_API_KEY=your-world-news-api-key

# GeoNames — powers Tribe "Today" candle-lighting city search (GET /api/tribe/cities).
# This is a free GeoNames ACCOUNT USERNAME (not an API key):
#   1. Create an account: https://www.geonames.org/login
#   2. Confirm the email, then enable the free web services on your account page:
#      https://www.geonames.org/manageaccount  → "Free Web Services" → click to enable
#   3. Put the username (not password) below.
# Free tier: ~20k credits/day, 1k/hour per username (the proxy caches queries ~1h).
# If unset, city search returns an empty list (typeahead silently shows no results).
GEONAMES_USERNAME=your-geonames-username

# Redis/Valkey (multi-instance Socket.IO adapter — optional in dev, required in production)
# REDIS_URL=rediss://default:password@hostname.db.ondigitalocean.com:25061

# Force-update gate (Phase 6 / FORCE-01)
# Operator bumps these only when a breaking server change is about to ship.
# Default 0.0.0 → gate is disabled, every client passes.
# Missing/empty also fail-open (treated as 0.0.0) so a misconfigured server
# never strands real users (D-01, D-03).
MIN_CLIENT_VERSION_IOS=0.0.0
MIN_CLIENT_VERSION_ANDROID=0.0.0

# Optional one-line message returned with force_update responses.
# Unset = no message field in the response (mobile uses its default copy).
# FORCE_UPDATE_MESSAGE=We're rolling out a critical fix — please update.

# Universal Links / App Links — REQUIRED in production for iOS + Android deep links.
# Served by src/routes/wellKnown.ts. Router returns 503 when either var is missing.
# APPLE_TEAM_ID: 10-char Apple Developer Team ID (Apple Developer → Membership).
# ANDROID_SHA256_FINGERPRINT: comma-separated list of colon-delimited SHA-256
#   certificate fingerprints. List BOTH keys from Play Console → Test and release
#   → App integrity → App signing:
#     1. "App signing key certificate" SHA-256 — REQUIRED. Play re-signs every
#        Store install with this key; Android verifies App Links against it.
#        Omitting it = "Failed domain checks" on all deep-link paths.
#     2. "Upload key certificate" SHA-256 — so EAS / internal-test builds (signed
#        with the upload key, not yet re-signed by Play) also verify.
#   Production value (app-signing key first, upload key second):
#   ANDROID_SHA256_FINGERPRINT=A9:ED:49:5F:53:9C:9D:90:A2:C0:E0:45:2D:81:66:08:C7:EA:8A:3D:E0:84:05:E0:7F:BD:74:7C:ED:C6:FB:10,CC:FD:F5:C6:1C:DB:42:C2:8F:E3:1A:7B:E1:BA:F5:D4:65:95:50:3A:88:EA:D9:29:7D:1B:A2:18:D2:F5:06:CE
APPLE_TEAM_ID=
ANDROID_SHA256_FINGERPRINT=

# Platform admin endpoints (/api/admin/*) — shared secret for x-admin-key header.
# Unset = admin endpoints disabled (503). Generate: openssl rand -hex 32
ADMIN_API_KEY=

# Referral — joiner premium grant (Phase 21 / REF-06)
# Number of free-premium days granted to a net-new joiner who provides a valid referrer.
# Default 14. Set to the desired value at deploy time; do not leave as 14 in production
# if a different duration is intended.
REFERRAL_JOINER_PREMIUM_DAYS=14

PUBLIC_API_URL=http://localhost:4000